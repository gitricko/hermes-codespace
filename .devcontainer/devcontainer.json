{
  "name": "Hermes-Coding-Agent",
  "customizations": {
    "vscode": {
      "extensions": ["joverina.rina-hermes-acp", "anthropic.claude-code","saoudrizwan.claude-dev"]
    }
  },
  "postCreateCommand": "touch /tmp/hermes-codespace.log && code /tmp/hermes-codespace.log && bash ./.devcontainer/post-create-cmd.sh >> /tmp/hermes-codespace.log 2>&1",
  "postStartCommand":  "touch /tmp/hermes-codespace.log && code /tmp/hermes-codespace.log && bash ./.devcontainer/start-hermes.sh  >> /tmp/hermes-codespace.log 2>&1"
}
